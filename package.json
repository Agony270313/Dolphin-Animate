{
  "name": "dolphin-animate",
  "version": "2.0.3",
  "description": "An open-source frame-by-frame animation tool",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build:vite": "vite build",
    "start": "npm run build:vite && electron .",
    "build": "npm run build:vite && electron-builder --publish=never",
    "build:publish": "npm run build:vite && electron-builder --publish=always"
  },
  "build": {
    "appId": "dolphin-animate.app",
    "productName": "Dolphin Animate",
    "directories": {
      "output": "C:/Users/tclpi/AppData/Local/Temp/opencode/dolphin-dist"
    },
    "icon": "icon.ico",
    "files": [
      "main.js",
      "dist/**/*",
      "package.json",
      "icon.ico",
      "!node_modules/**/ffmpeg.dll"
    ],
    "extraFiles": [
      "node_modules/electron/dist/ffmpeg.dll"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "Agony270313",
      "repo": "Dolphin-Animate"
    }
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-electron-renderer": "^1.0.0"
  },
  "dependencies": {
    "d3-contour": "^4.0.2",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "gif.js": "^0.2.0",
    "jsdom": "^29.1.1"
  }
}
